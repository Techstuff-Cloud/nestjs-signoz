{
  "name": "@techstuff-cloud/telemetry-backend",
  "version": "1.0.0",
  "description": "Shared OpenTelemetry logging for all NestJS backend projects — ships logs, traces and metrics to SigNoz",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "@nestjs/common": ">=10",
    "nestjs-pino": ">=4"
  },
  "dependencies": {
    "@opentelemetry/core": "^1.30.1",
    "@opentelemetry/exporter-logs-otlp-http": "^0.212.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.212.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.212.0",
    "@opentelemetry/instrumentation-express": "^0.60.0",
    "@opentelemetry/instrumentation-http": "^0.212.0",
    "@opentelemetry/instrumentation-nestjs-core": "^0.58.0",
    "@opentelemetry/instrumentation-pino": "^0.58.0",
    "@opentelemetry/resources": "^2.5.1",
    "@opentelemetry/sdk-logs": "^0.212.0",
    "@opentelemetry/sdk-metrics": "^2.5.1",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5"
  }
}